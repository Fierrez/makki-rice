#!/usr/bin/env bash
# =============================================================================
# makki-rice — Command Line Interface
# =============================================================================
# Installed to: ~/.local/bin/makki-rice
# =============================================================================

set -euo pipefail

RICE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info() { echo -e "${GREEN}[✓]${RESET} $*"; }
warn() { echo -e "${YELLOW}[!]${RESET} $*"; }
error() { echo -e "${RED}[✗]${RESET} $*"; exit 1; }

show_help() {
    echo -e "${CYAN}${BOLD}makki-rice CLI${RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Usage: makki-rice [options]"
    echo ""
    echo "Options:"
    echo "  --update, -u       Update makki-rice from GitHub and run bootstrap"
    echo "  --health, -c       Run health diagnostic checks"
    echo "  --theme, -t <name> Switch theme (mocha|latte|frappe|macchiato)"
    echo "  --restart, -r      Restart AGS shell daemon"
    echo "  --help, -h         Show this help message"
    echo ""
}

update_rice() {
    local target_dir="${HOME}/makki-rice"
    local branch="main"
    
    # Try to determine the active branch from the current directory
    if git rev-parse --git-dir &>/dev/null; then
        branch=$(git branch --show-current 2>/dev/null || echo "main")
    fi
    
    info "Starting clean update to VM native directory ($target_dir)..."
    
    # 1. Clone or update in the native directory
    if [ ! -d "$target_dir" ]; then
        info "Cloning fresh repository to native directory..."
        if ! git clone -b "$branch" https://github.com/Fierrez/makki-rice.git "$target_dir"; then
            error "Failed to clone repository to $target_dir."
        fi
    else
        info "Updating existing native repository..."
        cd "$target_dir"
        git fetch https://github.com/Fierrez/makki-rice.git "$branch"
        git reset --hard FETCH_HEAD
    fi
    
    # 2. Run bootstrap from the native directory
    info "Running bootstrap from native directory..."
    cd "$target_dir"
    chmod +x bootstrap.sh install.sh uninstall.sh makki-rice 2>/dev/null || true
    bash bootstrap.sh --force
    
    # 3. Reload session by exiting Hyprland
    info "Exiting Hyprland session to restart the GUI..."
    sleep 1
    hyprctl dispatch exit || killall Hyprland || true
}

case "${1:-}" in
    --update|-u)
        update_rice
        ;;
    --health|-c)
        bash "$RICE_DIR/tools/debug/health-check.sh"
        ;;
    --theme|-t)
        if [[ -z "${2:-}" ]]; then
            error "Please specify a theme name."
        fi
        bash "$RICE_DIR/scripts/system/theme-switch.sh" "$2"
        ;;
    --restart|-r)
        pkill -x ags || true
        sleep 0.5
        ags run &>/dev/null & disown
        info "AGS daemon restarted."
        ;;
    --help|-h|"")
        show_help
        ;;
    *)
        error "Unknown option: $1. Run 'makki-rice --help' for options."
        ;;
esac
