#!/usr/bin/env bash
# =============================================================================
# makki-rice — Command Line Interface
# =============================================================================
# Installed to: ~/.local/bin/makki-rice
# =============================================================================

set -euo pipefail

RICE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info() { echo -e "${GREEN}[✓]${RESET} $*"; }
warn() { echo -e "${YELLOW}[!]${RESET} $*"; }
error() { echo -e "${RED}[✗]${RESET} $*"; exit 1; }

show_help() {
    echo -e "${CYAN}${BOLD}makki-rice CLI${RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Usage: makki-rice [options]"
    echo ""
    echo "Options:"
    echo "  --update, -u       Update makki-rice from GitHub and run bootstrap"
    echo "  --health, -c       Run health diagnostic checks"
    echo "  --theme, -t <name> Switch theme (mocha|latte|frappe|macchiato)"
    echo "  --restart, -r      Restart AGS shell daemon"
    echo "  --help, -h         Show this help message"
    echo ""
}

update_rice() {
    info "Starting update..."
    cd "$RICE_DIR"
    
    # 1. Identify current branch name
    local branch
    branch=$(git branch --show-current 2>/dev/null || echo "main")
    
    # 2. Check for local modifications and stash if needed
    local stashed=false
    if ! git diff --quiet || ! git diff --cached --quiet; then
        info "Stashing local changes to prevent conflicts..."
        git stash -u
        stashed=true
    fi
    
    # 3. Fetch from public HTTPS repo to guarantee success without authentication prompt
    info "Fetching latest changes from GitHub (https://github.com/Fierrez/makki-rice)..."
    if ! git fetch https://github.com/Fierrez/makki-rice.git "$branch"; then
        error "Failed to fetch updates from GitHub."
    fi
    
    # 4. Merge changes or fall back to hard reset
    info "Applying updates..."
    if ! git merge FETCH_HEAD -m "Auto-merge updates via makki-rice --update" 2>/dev/null; then
        warn "Auto-merge failed. Force resetting local branch to match remote..."
        git reset --hard FETCH_HEAD
    fi
    
    # 5. Restore stashed local changes if they existed
    if [[ "$stashed" == "true" ]]; then
        info "Restoring your local changes..."
        if ! git stash pop; then
            warn "Conflicts detected when applying local changes. Your changes are saved in the git stash."
        fi
    fi
    
    # 6. Run bootstrap
    info "Running bootstrap..."
    bash bootstrap.sh
    
    # 7. Reload AGS & Hyprland
    info "Reloading session..."
    pkill -x ags || true
    sleep 0.5
    ags run &>/dev/null & disown
    sleep 0.5
    info "Reloading Hyprland config..."
    hyprctl reload || true
    
    info "Update complete! 🌿"
}

case "${1:-}" in
    --update|-u)
        update_rice
        ;;
    --health|-c)
        bash "$RICE_DIR/tools/debug/health-check.sh"
        ;;
    --theme|-t)
        if [[ -z "${2:-}" ]]; then
            error "Please specify a theme name."
        fi
        bash "$RICE_DIR/scripts/system/theme-switch.sh" "$2"
        ;;
    --restart|-r)
        pkill -x ags || true
        sleep 0.5
        ags run &>/dev/null & disown
        info "AGS daemon restarted."
        ;;
    --help|-h|"")
        show_help
        ;;
    *)
        error "Unknown option: $1. Run 'makki-rice --help' for options."
        ;;
esac
